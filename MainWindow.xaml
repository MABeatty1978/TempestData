<Window x:Class="TempestData.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Tempest Weather Station Viewer" Height="900" Width="1000">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="ExitMenuItem_Click" />
            </MenuItem>
            <MenuItem Header="_Station">
                <MenuItem Header="_Refresh Station" Click="RefreshStationsButton_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="API Token Help" Click="ApiKeyHelpMenuItem_Click" />
                <MenuItem Header="Check for _Updates" Click="CheckUpdatesMenuItem_Click" />
                <MenuItem Header="About" Click="HelpAboutMenuItem_Click" />
            </MenuItem>
        </Menu>
        <Grid Margin="12">
            <Grid.Resources>
                <Style TargetType="ComboBox">
                    <Setter Property="MinWidth" Value="160" />
                    <Setter Property="MaxWidth" Value="240" />
                    <Setter Property="Height" Value="28" />
                </Style>
                <Style TargetType="TextBox">
                    <Setter Property="MinWidth" Value="160" />
                    <Setter Property="MaxWidth" Value="260" />
                    <Setter Property="Height" Value="28" />
                </Style>
                <Style x:Key="FormLabel" TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Margin" Value="0,0,10,0" />
                </Style>
                <Style x:Key="ControlGroup" TargetType="StackPanel">
                    <Setter Property="Margin" Value="0,0,4,12" />
                </Style>
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <GroupBox Header="Connection &amp; Station" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Tempest API Token:" VerticalAlignment="Center" HorizontalAlignment="Right" TextAlignment="Right" />
                    <Grid Grid.Column="1" Margin="4,0,0,8" Width="260" HorizontalAlignment="Left">
                        <TextBox x:Name="ApiKeyBox" Width="260" HorizontalAlignment="Left" VerticalContentAlignment="Center" />
                        <TextBlock Text='See "Help" to get token' Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#8A8A8A" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=ApiKeyBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <TextBlock Text="Station:" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Right" TextAlignment="Right" />
                    <ComboBox x:Name="StationComboBox" Grid.Row="1" Grid.Column="1" Margin="4,0,0,0" Width="260" MaxWidth="260" HorizontalAlignment="Left" SelectionChanged="StationComboBox_SelectionChanged" />
                    <Button x:Name="SaveSettingsButton" Grid.Row="0" Grid.Column="2" Margin="10,0,0,8" Width="120" Padding="10,4" HorizontalAlignment="Right" Content="Save Settings" Click="SaveSettingsButton_Click" />
                    <Button x:Name="KoFiButton" Grid.Row="1" Grid.Column="2" Margin="10,0,0,0" Width="120" Padding="10,4" HorizontalAlignment="Right" Content="Tip on Ko-fi" Click="KoFiButton_Click" />
                </Grid>
            </GroupBox>

            <StackPanel Orientation="Vertical" Grid.Row="1" Margin="0,0,0,10">
            <GroupBox Header="Filters &amp; Export" Padding="14" Grid.Row="1" Margin="0,0,0,12">
                <Grid HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Style="{StaticResource ControlGroup}">
                        <TextBlock Text="Resolution" />
                        <ComboBox x:Name="BucketComboBox" Width="90" MinWidth="90" MaxWidth="90" HorizontalAlignment="Left" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Style="{StaticResource ControlGroup}">
                        <TextBlock Text="Temp units" />
                        <ComboBox x:Name="UnitsTempComboBox" Width="90" MinWidth="90" MaxWidth="90" HorizontalAlignment="Left" SelectionChanged="UnitSelectionChanged" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Style="{StaticResource ControlGroup}">
                        <TextBlock Text="Wind units" />
                        <ComboBox x:Name="UnitsWindComboBox" Width="90" MinWidth="90" MaxWidth="90" HorizontalAlignment="Left" SelectionChanged="UnitSelectionChanged" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Style="{StaticResource ControlGroup}">
                        <TextBlock Text="Pressure units" />
                        <ComboBox x:Name="UnitsPressureComboBox" Width="90" MinWidth="90" MaxWidth="90" HorizontalAlignment="Left" SelectionChanged="UnitSelectionChanged" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Style="{StaticResource ControlGroup}">
                        <TextBlock Text="Precip units" />
                        <ComboBox x:Name="UnitsPrecipComboBox" Width="90" MinWidth="90" MaxWidth="90" HorizontalAlignment="Left" SelectionChanged="UnitSelectionChanged" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Style="{StaticResource ControlGroup}">
                        <TextBlock Text="Distance units" />
                        <ComboBox x:Name="UnitsDistanceComboBox" Width="90" MinWidth="90" MaxWidth="90" HorizontalAlignment="Left" SelectionChanged="UnitSelectionChanged" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="3" Style="{StaticResource ControlGroup}">
                        <TextBlock x:Name="StartLabel" Text="Start" VerticalAlignment="Center" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <DatePicker x:Name="StartDatePicker" Width="140" VerticalContentAlignment="Center" />
                            <TextBox x:Name="StartTimeBox" Grid.Column="1" Width="72" MinWidth="72" MaxWidth="72" Text="00:00" Margin="8,0,0,0" VerticalContentAlignment="Center" />
                            <ComboBox x:Name="TimeZoneComboBox" Grid.Column="2" MinWidth="170" Margin="8,0,0,0" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" SelectionChanged="TimeZoneComboBox_SelectionChanged" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="3" Style="{StaticResource ControlGroup}">
                        <TextBlock x:Name="EndLabel" Text="End" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <DatePicker x:Name="EndDatePicker" Width="140" VerticalContentAlignment="Center" />
                            <TextBox x:Name="EndTimeBox" Width="72" MinWidth="72" MaxWidth="72" Text="23:59" Margin="8,0,0,0" VerticalContentAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,0,0,0">
                        <TextBlock Text="Select observation fields" />
                        <ItemsControl x:Name="FieldCheckList" Margin="0,4,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,12,6" Checked="FieldCheckBox_Changed" Unchecked="FieldCheckBox_Changed" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,10,0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Page size limit" VerticalAlignment="Center" />
                        <TextBox x:Name="PageSizeBox" Width="120" MinWidth="120" MaxWidth="120" HorizontalAlignment="Left" Margin="8,0,0,0" Text="250" VerticalContentAlignment="Center" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="LoadButton" Grid.Column="0" Content="Load Observations" Padding="14,6" Click="LoadButton_Click" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ExportButton" Content="Export" Padding="14,6" Click="ExportButton_Click" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <GroupBox Header="Observation Data" Grid.Row="2" Padding="10">
            <DataGrid x:Name="ObservationDataGrid" AutoGenerateColumns="True" IsReadOnly="True" CanUserAddRows="False" />
        </GroupBox>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="3" Margin="0,10,0,0" TextWrapping="Wrap" />
    </Grid>
    </DockPanel>
</Window>
